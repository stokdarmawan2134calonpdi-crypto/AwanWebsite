.social-link.whatsapp:hover{background:#25D366;color:#000;box-shadow:0 4px 16px rgba(37,211,102,0.4)}
.social-link.discord{background:rgba(114,137,218,0.1);color:#7289da;border:1px solid rgba(114,137,218,0.3)}
.social-link.discord:hover{background:#7289da;color:#fff}
