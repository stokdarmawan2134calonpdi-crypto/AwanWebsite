.footer-desc{color:var(--text-muted);font-size:13px;line-height:1.7;max-width:400px}
.footer-social{display:flex;gap:10px;flex-wrap:wrap}
.social-link{display:flex;align-items:center;gap:8px;padding:9px 18px;border-radius:50px;text-decoration:none;font-size:13px;font-weight:700;transition:all 0.3s ease}
